{
  "project": "civic-pulse",
  "stack": {
    "host": "cloudflare-workers",
    "framework": "tanstack-start",
    "backend": "convex",
    "auth": "workos",
    "packageManager": "bun",
    "packageManagerField": null,
    "publicPrefix": "VITE_"
  },
  "vaults": {
    "app": "civic-pulse-app",
    "ci": "civic-pulse-ci"
  },
  "source": {
    "kind": "env-files",
    "envFiles": [
      ".env.example"
    ]
  },
  "ignorePrefixes": [],
  "environments": [
    {
      "name": "dev",
      "sourceConfig": ".env.example",
      "branch": null,
      "wranglerEnv": null,
      "wranglerConfigs": null,
      "convexDeployTarget": "dev",
      "vercelEnvironment": null,
      "githubEnvironment": null,
      "easProfile": null
    },
    {
      "name": "production",
      "sourceConfig": ".env.production",
      "branch": "main",
      "wranglerEnv": null,
      "wranglerConfigs": [
        "wrangler.jsonc"
      ],
      "convexDeployTarget": "prod",
      "vercelEnvironment": null,
      "githubEnvironment": "production",
      "easProfile": null
    }
  ],
  "keys": {
    "CLOUDFLARE_ACCOUNT_ID": {
      "class": "secret",
      "vault": "ci",
      "destinations": [
        "github-env"
      ]
    },
    "CLOUDFLARE_API_TOKEN": {
      "class": "secret",
      "vault": "ci",
      "destinations": [
        "github-env"
      ]
    },
    "CONVEX_DEPLOYMENT": {
      "class": "ignore",
      "destinations": []
    },
    "CONVEX_DEPLOY_KEY": {
      "class": "secret",
      "vault": "ci",
      "destinations": [
        "github-env"
      ]
    },
    "OPENROUTER_API_KEY": {
      "class": "secret",
      "vault": "app",
      "destinations": [
        "convex"
      ]
    },
    "RESEND_API_KEY": {
      "class": "secret",
      "vault": "app",
      "destinations": [
        "convex"
      ]
    },
    "STRIPE_PRO_PRICE_ID": {
      "class": "secret",
      "vault": "app",
      "destinations": [
        "convex"
      ]
    },
    "STRIPE_SECRET_KEY": {
      "class": "secret",
      "vault": "app",
      "destinations": [
        "convex",
        "worker"
      ]
    },
    "STRIPE_WEBHOOK_SECRET": {
      "class": "secret",
      "vault": "app",
      "destinations": [
        "worker"
      ]
    },
    "VITE_APP_URL": {
      "class": "public",
      "destinations": [
        "bundle"
      ]
    },
    "VITE_CONVEX_URL": {
      "class": "public",
      "destinations": [
        "bundle"
      ]
    },
    "VITE_WORKOS_CLIENT_ID": {
      "class": "public",
      "destinations": [
        "bundle"
      ]
    },
    "VITE_WORKOS_REDIRECT_URI": {
      "class": "public",
      "destinations": [
        "bundle"
      ]
    },
    "WORKOS_API_KEY": {
      "class": "secret",
      "vault": "app",
      "destinations": [
        "worker"
      ]
    },
    "WORKOS_CLIENT_ID": {
      "class": "secret",
      "vault": "app",
      "destinations": [
        "worker"
      ]
    },
    "WORKOS_COOKIE_PASSWORD": {
      "class": "secret",
      "vault": "app",
      "destinations": [
        "worker"
      ]
    },
    "WORKOS_REDIRECT_URI": {
      "class": "secret",
      "vault": "app",
      "destinations": [
        "worker"
      ]
    }
  }
}
