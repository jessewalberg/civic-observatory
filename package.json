{
	"name": "civic-observatory",
	"description": "Municipal meeting summarizer - AI-powered summaries of local government meetings",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "npx convex codegen && vite build && tsc --noEmit",
		"preview": "vite preview",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check",
		"audit:municipality": "node scripts/municipality-data-audit.mjs",
		"requeue:municipality": "node scripts/requeue-municipality-meetings.mjs",
		"unstick:processing": "node scripts/unstick-processing-meetings.mjs",
		"convex:push": "bunx convex dev --once",
		"deploy": "npx convex deploy && pnpm run build",
		"deploy:convex": "npx convex deploy"
	},
	"dependencies": {
		"@clerk/clerk-react": "^5.61.3",
