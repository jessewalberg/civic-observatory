# ===========================================
# Civic Observatory Environment Configuration
# ===========================================

# Convex Backend
# Get these from: https://dashboard.convex.dev
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# -------------------------------------------
# AI / LLM Configuration
# -------------------------------------------
# OpenRouter API Key for AI summarization (multi-model gateway)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# -------------------------------------------
# Stripe Payments
# Get from: https://dashboard.stripe.com/developers
# -------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create a product in Stripe and get the price ID for your Pro plan
STRIPE_PRO_PRICE_ID=

# -------------------------------------------
# Application URL
# -------------------------------------------
VITE_APP_URL=http://localhost:3000

# Clerk auth (required — WorkOS removed in the Phase 3+ migration)
# Server (Cloudflare Worker secret): CLERK_SECRET_KEY, CLERK_JWT_ISSUER_DOMAIN
# Client (bundle): VITE_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=
VITE_CLERK_PUBLISHABLE_KEY=
