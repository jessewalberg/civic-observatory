# ===========================================
# Civic Pulse Environment Configuration
# ===========================================

# Convex Backend
# Get these from: https://dashboard.convex.dev
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# -------------------------------------------
# WorkOS AuthKit (Server-side)
# Get these from: https://dashboard.workos.com
# -------------------------------------------
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
WORKOS_COOKIE_PASSWORD=your-32-character-or-longer-password-here

# Optional WorkOS settings
# WORKOS_COOKIE_NAME=wos-session
# WORKOS_API_HOSTNAME=api.workos.com

# -------------------------------------------
# WorkOS AuthKit (Client-side / Vite)
# These are exposed to the browser
# -------------------------------------------
VITE_WORKOS_CLIENT_ID=
VITE_WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback

# -------------------------------------------
# AI / LLM Configuration
# -------------------------------------------
# OpenRouter API Key for AI summarization (multi-model gateway)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# -------------------------------------------
# Stripe Payments
# Get from: https://dashboard.stripe.com/developers
# -------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create a product in Stripe and get the price ID for your Pro plan
STRIPE_PRO_PRICE_ID=

# -------------------------------------------
# Application URL
# -------------------------------------------
VITE_APP_URL=http://localhost:3000

# Clerk (Phase 1+ of the WorkOS→Clerk migration — leave unset to keep WorkOS)
VITE_CLERK_PUBLISHABLE_KEY=
