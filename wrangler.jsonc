{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "civic-observatory",
  "main": "@tanstack/react-start/server-entry",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  // Environment variables - set these in Cloudflare dashboard or use .dev.vars locally
  // Required vars (use wrangler secret put for sensitive values):
  // - CLERK_SECRET_KEY
  // - CLERK_JWT_ISSUER_DOMAIN
  // - VITE_CLERK_PUBLISHABLE_KEY
  // - OPENROUTER_API_KEY
  "vars": {
    // Public vars can be set here
  }
}
